generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  INTERNAL
  CUSTOMER
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  EXPIRED
  CONVERTED
}

enum OrderStatus {
  DRAFT
  APPROVED
  IN_PRODUCTION
  SHIPPED
  CLOSED
  HOLD
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  REFUNDED
}

enum ProductionStatus {
  NEEDS_PROOF
  READY
  PRINTING
  PACKING
  SHIPPED
}

enum LedgerType {
  ADJUST
  RESERVE
  RELEASE
  CONSUME
  RECEIVE
}

enum ProviderType {
  MOCK
  STRIPE
  SHIPPO
  AVALARA
  CUSTOM
}

model Tenant {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  status         String         @default("active")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  users          User[]
  roles          Role[]
  stores         Store[]
  customers      Customer[]
  companies      Company[]
  vendors        Vendor[]
  webhooks       Webhook[]
  automations    AutomationRule[]
  activities     ActivityLog[]
  subscriptions  Subscription[]
  notifications  Notification[]
  files          FileAsset[]
  audits         AuditEntry[]

  @@index([updatedAt, id])
}

model User {
  id              String       @id @default(cuid())
  tenantId        String
  email           String
  passwordHash    String
  firstName       String
  lastName        String
  type            UserType     @default(INTERNAL)
  isActive        Boolean      @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  stores          Store[]      @relation("StoreOwner")
  roles           UserRole[]
  designs         Design[]
  quotes          Quote[]      @relation("QuoteOwner")
  orders          Order[]      @relation("OrderOwner")
  messages        Message[]
  auditEntries    AuditEntry[]
  refreshTokens   RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId, updatedAt, id])
}

model RefreshToken {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([tenantId, userId, expiresAt])
}

model Role {
  id            String           @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  isSystem      Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  users         UserRole[]
  permissions   RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId, updatedAt, id])
}

model Permission {
  id            String           @id @default(cuid())
  key           String           @unique
  label         String
  description   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  roles         RolePermission[]
}

model RolePermission {
  id            String      @id @default(cuid())
  roleId        String
  permissionId  String
  createdAt     DateTime    @default(now())
  role          Role        @relation(fields: [roleId], references: [id])
  permission    Permission  @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model UserRole {
  id            String      @id @default(cuid())
  userId        String
  roleId        String
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id])
  role          Role        @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model Store {
  id               String             @id @default(cuid())
  tenantId         String
  slug             String
  name             String
  domain           String?
  currency         String             @default("USD")
  timezone         String             @default("UTC")
  ownerUserId      String?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  owner            User?              @relation("StoreOwner", fields: [ownerUserId], references: [id])
  theme            StoreTheme?
  pages            Page[]
  products         Product[]
  pricingRules     PricingRule[]
  pricingTiers     PricingTier[]
  markupRules      MarkupRule[]
  designs          Design[]
  orders           Order[]
  quotes           Quote[]
  invoices         Invoice[]
  jobs             ProductionJob[]
  vendors          Vendor[]
  inventory        Inventory[]
  webhooks         Webhook[]
  automations      AutomationRule[]
  activity         ActivityLog[]
  notifications    Notification[]
  savedCarts       SavedCart[]
  files            FileAsset[]

  @@unique([tenantId, slug])
  @@unique([domain])
  @@index([tenantId, updatedAt, id])
}

model StoreTheme {
  id             String    @id @default(cuid())
  tenantId       String
  storeId        String    @unique
  primaryColor   String?
  secondaryColor String?
  logoUrl        String?
  fontFamily     String?
  settings       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  store          Store     @relation(fields: [storeId], references: [id])

  @@index([tenantId, updatedAt, id])
}

model Page {
  id             String    @id @default(cuid())
  tenantId       String
  storeId        String
  slug           String
  title          String
  isPublished    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  store          Store     @relation(fields: [storeId], references: [id])
  sections       Section[]

  @@unique([storeId, slug])
  @@index([tenantId, storeId, updatedAt, id])
}

model Section {
  id             String    @id @default(cuid())
  tenantId       String
  pageId         String
  type           String
  position       Int
  props          Json
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  page           Page      @relation(fields: [pageId], references: [id])

  @@index([tenantId, pageId, position])
}

model Product {
  id             String         @id @default(cuid())
  tenantId       String
  storeId        String
  slug           String
  name           String
  description    String?
  category       String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  store          Store          @relation(fields: [storeId], references: [id])
  variants       Variant[]
  printAreas     PrintArea[]
  orderItems     OrderItem[]
  quoteItems     QuoteItem[]
  vendorProducts VendorProduct[]

  @@unique([storeId, slug])
  @@index([tenantId, storeId, updatedAt, id])
}

model Variant {
  id               String         @id @default(cuid())
  tenantId         String
  storeId          String
  productId        String
  sku              String
  name             String
  color            String?
  size             String?
  baseCost         Decimal        @db.Decimal(10, 2)
  basePrice        Decimal        @db.Decimal(10, 2)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  product          Product        @relation(fields: [productId], references: [id])
  inventory        Inventory[]
  designLayers     DesignLayer[]
  orderItems       OrderItem[]
  quoteItems       QuoteItem[]
  vendorVariants   VendorVariant[]

  @@unique([storeId, sku])
  @@index([tenantId, storeId, updatedAt, id])
}

model DecorationMethod {
  id             String         @id @default(cuid())
  tenantId       String
  storeId        String?
  code           String
  name           String
  config         Json
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  pricingRules   PricingRule[]

  @@unique([tenantId, code])
  @@index([tenantId, updatedAt, id])
}

model PricingRule {
  id             String            @id @default(cuid())
  tenantId       String
  storeId        String
  name           String
  methodId       String?
  priority       Int               @default(100)
  conditions     Json
  formula        Json
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  store          Store             @relation(fields: [storeId], references: [id])
  method         DecorationMethod? @relation(fields: [methodId], references: [id])

  @@index([tenantId, storeId, priority, updatedAt, id])
}

model PricingTier {
  id             String    @id @default(cuid())
  tenantId       String
  storeId        String
  name           String
  rank           Int
  config         Json
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  store          Store     @relation(fields: [storeId], references: [id])

  @@unique([storeId, name])
  @@index([tenantId, storeId, rank])
}

model MarkupRule {
  id             String    @id @default(cuid())
  tenantId       String
  storeId        String
  name           String
  percentage     Decimal   @db.Decimal(6, 2)
  minMargin      Decimal?  @db.Decimal(10, 2)
  conditions     Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  store          Store     @relation(fields: [storeId], references: [id])

  @@index([tenantId, storeId, updatedAt, id])
}

model Design {
  id             String       @id @default(cuid())
  tenantId       String
  storeId        String
  userId         String
  name           String
  version        Int          @default(1)
  canvasWidth    Int
  canvasHeight   Int
  previewUrl     String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  store          Store        @relation(fields: [storeId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  layers         DesignLayer[]
  quoteItems     QuoteItem[]
  orderItems     OrderItem[]

  @@index([tenantId, storeId, updatedAt, id])
}

model DesignLayer {
  id             String    @id @default(cuid())
  tenantId       String
  designId       String
  variantId      String?
  type           String
  positionX      Float
  positionY      Float
  width          Float
  height         Float
  rotation       Float      @default(0)
  opacity        Float      @default(1)
  content        Json
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?
  design         Design     @relation(fields: [designId], references: [id])
  variant        Variant?   @relation(fields: [variantId], references: [id])

  @@index([tenantId, designId, updatedAt, id])
}

model PrintArea {
  id             String    @id @default(cuid())
  tenantId       String
  productId      String
  code           String
  widthIn        Float
  heightIn       Float
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  product        Product   @relation(fields: [productId], references: [id])

  @@unique([productId, code])
  @@index([tenantId, updatedAt, id])
}

model Quote {
  id             String       @id @default(cuid())
  tenantId       String
  storeId        String
  customerId     String
  ownerUserId    String?
  number         String
  status         QuoteStatus  @default(DRAFT)
  subtotal       Decimal      @db.Decimal(12, 2)
  taxTotal       Decimal      @db.Decimal(12, 2)
  shippingTotal  Decimal      @db.Decimal(12, 2)
  grandTotal     Decimal      @db.Decimal(12, 2)
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  store          Store        @relation(fields: [storeId], references: [id])
  customer       Customer     @relation(fields: [customerId], references: [id])
  owner          User?        @relation("QuoteOwner", fields: [ownerUserId], references: [id])
  items          QuoteItem[]

  @@unique([storeId, number])
  @@index([tenantId, storeId, updatedAt, id])
}

model QuoteItem {
  id               String    @id @default(cuid())
  tenantId         String
  quoteId          String
  productId        String
  variantId        String
  designId         String?
  quantity         Int
  unitPrice        Decimal   @db.Decimal(10, 2)
  lineTotal        Decimal   @db.Decimal(12, 2)
  pricingSnapshot  Json
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  quote            Quote     @relation(fields: [quoteId], references: [id])
  product          Product   @relation(fields: [productId], references: [id])
  variant          Variant   @relation(fields: [variantId], references: [id])
  design           Design?   @relation(fields: [designId], references: [id])

  @@index([tenantId, quoteId, updatedAt, id])
}

model Order {
  id             String       @id @default(cuid())
  tenantId       String
  storeId        String
  customerId     String
  ownerUserId    String?
  quoteId        String?
  number         String
  status         OrderStatus  @default(DRAFT)
  subtotal       Decimal      @db.Decimal(12, 2)
  taxTotal       Decimal      @db.Decimal(12, 2)
  shippingTotal  Decimal      @db.Decimal(12, 2)
  grandTotal     Decimal      @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  store          Store        @relation(fields: [storeId], references: [id])
  customer       Customer     @relation(fields: [customerId], references: [id])
  owner          User?        @relation("OrderOwner", fields: [ownerUserId], references: [id])
  quote          Quote?       @relation(fields: [quoteId], references: [id])
  items          OrderItem[]
  invoices       Invoice[]
  jobs           ProductionJob[]
  payments       PaymentRecord[]

  @@unique([storeId, number])
  @@index([tenantId, storeId, status, updatedAt, id])
}

model OrderItem {
  id               String    @id @default(cuid())
  tenantId         String
  orderId          String
  productId        String
  variantId        String
  designId         String?
  quantity         Int
  unitPrice        Decimal   @db.Decimal(10, 2)
  lineTotal        Decimal   @db.Decimal(12, 2)
  pricingSnapshot  Json
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  order            Order     @relation(fields: [orderId], references: [id])
  product          Product   @relation(fields: [productId], references: [id])
  variant          Variant   @relation(fields: [variantId], references: [id])
  design           Design?   @relation(fields: [designId], references: [id])

  @@index([tenantId, orderId, updatedAt, id])
}

model Invoice {
  id             String        @id @default(cuid())
  tenantId       String
  storeId        String
  orderId        String
  number         String
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime?
  subtotal       Decimal       @db.Decimal(12, 2)
  taxTotal       Decimal       @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  store          Store         @relation(fields: [storeId], references: [id])
  order          Order         @relation(fields: [orderId], references: [id])

  @@unique([storeId, number])
  @@index([tenantId, storeId, status, updatedAt, id])
}

model Customer {
  id             String      @id @default(cuid())
  tenantId       String
  storeId        String?
  companyId      String?
  userId         String?
  email          String
  firstName      String
  lastName       String
  phone          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  company        Company?    @relation(fields: [companyId], references: [id])
  quotes         Quote[]
  orders         Order[]

  @@index([tenantId, updatedAt, id])
  @@unique([tenantId, email])
}

model Company {
  id             String      @id @default(cuid())
  tenantId       String
  name           String
  taxId          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  customers      Customer[]

  @@unique([tenantId, name])
}

model WorkflowStage {
  id             String      @id @default(cuid())
  tenantId       String
  storeId        String
  code           String
  label          String
  order          Int
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  jobs           ProductionJob[]

  @@unique([storeId, code])
  @@index([tenantId, storeId, order])
}

model ProductionJob {
  id             String           @id @default(cuid())
  tenantId       String
  storeId        String
  orderId        String
  stageId        String?
  status         ProductionStatus @default(NEEDS_PROOF)
  dueAt          DateTime?
  priority       Int              @default(100)
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  store          Store            @relation(fields: [storeId], references: [id])
  order          Order            @relation(fields: [orderId], references: [id])
  stage          WorkflowStage?   @relation(fields: [stageId], references: [id])
  inventory      Inventory[]

  @@index([tenantId, storeId, status, priority, updatedAt, id])
}

model Vendor {
  id             String      @id @default(cuid())
  tenantId       String
  storeId        String?
  name           String
  provider       ProviderType @default(MOCK)
  externalId     String?
  config         Json?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  store          Store?      @relation(fields: [storeId], references: [id])
  products       VendorProduct[]

  @@index([tenantId, updatedAt, id])
}

model VendorProduct {
  id             String         @id @default(cuid())
  tenantId       String
  vendorId       String
  productId      String?
  externalId     String
  name           String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  vendor         Vendor         @relation(fields: [vendorId], references: [id])
  product        Product?       @relation(fields: [productId], references: [id])
  variants       VendorVariant[]

  @@unique([vendorId, externalId])
  @@index([tenantId, updatedAt, id])
}

model VendorVariant {
  id             String      @id @default(cuid())
  tenantId       String
  vendorProductId String
  variantId      String?
  externalId     String
  sku            String
  cost           Decimal     @db.Decimal(10, 2)
  inventoryQty   Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  vendorProduct  VendorProduct @relation(fields: [vendorProductId], references: [id])
  variant        Variant?      @relation(fields: [variantId], references: [id])

  @@unique([vendorProductId, externalId])
  @@index([tenantId, updatedAt, id])
}

model Inventory {
  id             String      @id @default(cuid())
  tenantId       String
  storeId        String
  variantId      String
  productionJobId String?
  orderItemId    String?
  location       String
  type           LedgerType
  quantity       Int
  note           String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  variant        Variant     @relation(fields: [variantId], references: [id])
  job            ProductionJob? @relation(fields: [productionJobId], references: [id])

  @@index([tenantId, storeId, variantId, createdAt, id])
}

model Webhook {
  id             String      @id @default(cuid())
  tenantId       String
  storeId        String?
  provider       ProviderType @default(MOCK)
  eventType      String
  endpoint       String
  secretHash     String?
  isActive       Boolean     @default(true)
  lastEventId    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  store          Store?      @relation(fields: [storeId], references: [id])

  @@index([tenantId, provider, eventType, updatedAt, id])
}

model AutomationRule {
  id             String      @id @default(cuid())
  tenantId       String
  storeId        String?
  name           String
  triggerType    String
  conditions     Json?
  actions        Json
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  store          Store?      @relation(fields: [storeId], references: [id])

  @@index([tenantId, updatedAt, id])
}

model ActivityLog {
  id             String      @id @default(cuid())
  tenantId       String
  storeId        String?
  actorUserId    String?
  entityType     String
  entityId       String
  action         String
  payload        Json?
  requestId      String?
  createdAt      DateTime    @default(now())
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  store          Store?      @relation(fields: [storeId], references: [id])

  @@index([tenantId, createdAt, id])
}

model Plan {
  id             String      @id @default(cuid())
  code           String      @unique
  name           String
  monthlyPrice   Decimal     @db.Decimal(10, 2)
  annualPrice    Decimal?    @db.Decimal(10, 2)
  limits         Json
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  subscriptions  Subscription[]
}

model Subscription {
  id             String      @id @default(cuid())
  tenantId       String
  planId         String
  status         String
  startsAt       DateTime
  endsAt         DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  plan           Plan        @relation(fields: [planId], references: [id])

  @@index([tenantId, status, updatedAt, id])
}

model PaymentRecord {
  id             String      @id @default(cuid())
  tenantId       String
  orderId        String
  provider       ProviderType @default(MOCK)
  providerRef    String?
  amount         Decimal     @db.Decimal(12, 2)
  currency       String      @default("USD")
  status         String
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  order          Order       @relation(fields: [orderId], references: [id])

  @@index([tenantId, status, updatedAt, id])
}

model Notification {
  id             String      @id @default(cuid())
  tenantId       String
  storeId        String?
  userId         String?
  channel        String
  subject        String
  body           String
  status         String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  store          Store?      @relation(fields: [storeId], references: [id])

  @@index([tenantId, status, createdAt, id])
}

model Message {
  id             String      @id @default(cuid())
  tenantId       String
  customerId     String?
  userId         String?
  direction      String
  channel        String
  content        String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User?       @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt, id])
}

model SavedCart {
  id             String      @id @default(cuid())
  tenantId       String
  storeId        String
  customerId     String
  payload        Json
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  store          Store       @relation(fields: [storeId], references: [id])

  @@index([tenantId, storeId, updatedAt, id])
}

model FileAsset {
  id             String      @id @default(cuid())
  tenantId       String
  storeId        String?
  key            String      @unique
  bucket         String
  mimeType       String
  sizeBytes      Int
  width          Int?
  height         Int?
  checksum       String?
  metadata       Json?
  createdById    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  store          Store?      @relation(fields: [storeId], references: [id])

  @@index([tenantId, storeId, createdAt, id])
}

model AuditEntry {
  id             String      @id @default(cuid())
  tenantId       String
  actorUserId    String?
  entityType     String
  entityId       String
  action         String
  summary        String
  before         Json?
  after          Json?
  requestId      String?
  ip             String?
  userAgent      String?
  createdAt      DateTime    @default(now())
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  actor          User?       @relation(fields: [actorUserId], references: [id])

  @@index([tenantId, createdAt, id])
  @@index([tenantId, entityType, entityId, createdAt])
}
