# Frontend environment variables
# Prefer same-origin '/api' via rewrites/proxy for production
VITE_API_URL=/api

# Optional flags
VITE_USE_MOCKS=false
VITE_API_TIMEOUT=30000
VITE_ENABLE_ANALYTICS=false

# Deploy proof metadata (usually injected by Vite config / CI)
VITE_GIT_COMMIT=local
VITE_BUILD_TIME=2026-01-01T00:00:00.000Z
